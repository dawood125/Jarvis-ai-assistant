# Client-side model call guard (default false for local-safe mode)
VITE_ENABLE_CLIENT_MODEL_CALLS=false

# Groq provider
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter provider
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini
VITE_OPENROUTER_REFERER=http://localhost:5173
VITE_OPENROUTER_APP_TITLE=Jarvis Local Prototype
