# Preferred secure bridge mode (frontend)
VITE_USE_MODEL_BRIDGE=true
VITE_MODEL_BRIDGE_URL=

# Optional direct client fallback (not recommended for production)
VITE_ENABLE_CLIENT_MODEL_CALLS=false
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.1-8b-instant
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini
VITE_OPENROUTER_REFERER=http://localhost:5173
VITE_OPENROUTER_APP_TITLE=Jarvis Local Prototype

# Secure bridge server settings
MODEL_BRIDGE_PORT=8787
MODEL_BRIDGE_REQUEST_TIMEOUT_MS=12000
MODEL_BRIDGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MODEL_BRIDGE_PROXY_TARGET=http://localhost:8787
SYSTEM_ACTIONS_ENABLED=false
SYSTEM_TELEMETRY_REFRESH_MS=5000
SYSTEM_PING_HOST=1.1.1.1

# Frontend safety flag for real launch execution
VITE_ENABLE_SYSTEM_ACTIONS=false

# Optional app command overrides for bridge launch adapter
SYSTEM_APP_VSCODE=code
SYSTEM_APP_TERMINAL=wt
SYSTEM_APP_CHROME=chrome
SYSTEM_APP_SPOTIFY=spotify

# Provider keys for secure bridge (recommended)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Jarvis Secure Bridge
